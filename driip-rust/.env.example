# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/driip

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_ACCESS_TTL_SECS=900       # 15 minutes
JWT_REFRESH_TTL_SECS=604800   # 7 days

# ── Cache (Upstash Redis) ─────────────────────────────────────────────────────
UPSTASH_REDIS_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# ── GHTK Courier ─────────────────────────────────────────────────────────────
GHTK_TOKEN=your_ghtk_api_token
GHTK_SANDBOX=true              # Set to false for production
GHTK_WEBHOOK_SECRET=your_hmac_webhook_secret

# Warehouse pickup address
GHTK_PICK_NAME=Driip Warehouse
GHTK_PICK_ADDRESS=123 Nguyen Van Linh
GHTK_PICK_PROVINCE=TP. Hồ Chí Minh
GHTK_PICK_DISTRICT=Quận 7
GHTK_PICK_TEL=0900000000
