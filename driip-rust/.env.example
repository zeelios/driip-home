# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/driip

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_ACCESS_TTL_SECS=900       # 15 minutes
JWT_REFRESH_TTL_SECS=604800   # 7 days

# ── GHTK Courier ─────────────────────────────────────────────────────────────
GHTK_TOKEN=your_ghtk_api_token
GHTK_SANDBOX=true              # Set to false for production
GHTK_WEBHOOK_SECRET=your_hmac_webhook_secret
GHTK_PARTNER_CODE=your_partner_code  # Required for X-Client-Source header in new API

# Warehouse pickup address
GHTK_PICK_NAME=Driip Warehouse
GHTK_PICK_ADDRESS=123 Nguyen Van Linh
GHTK_PICK_PROVINCE=TP. Hồ Chí Minh
GHTK_PICK_DISTRICT=Quận 7
GHTK_PICK_TEL=0900000000

# ── Stripe Payments ───────────────────────────────────────────────────────────
# All optional — app boots fine without Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Backblaze B2 (File Uploads) ───────────────────────────────────────────────
# All optional — uploads disabled if not configured
B2_ACCOUNT_ID=0021f69016a02cd000000000e              # Your B2 Key ID
B2_APPLICATION_KEY=K002CT8UpCYjmISYq1fe8We5OaLoNVc   # Your B2 Application Key
B2_BUCKET_ID=016f7629003146fa90c20c1d
B2_BUCKET_NAME=driipPanel
B2_CDN_URL=https://s3.us-west-002.backblazeb2.com  # Optional: use custom CDN domain if configured