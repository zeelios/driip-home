{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT oi.id, oi.product_id, oi.quantity, oi.reserved_qty,\n                   (oi.quantity - oi.reserved_qty) AS still_needed\n            FROM order_items oi\n            WHERE oi.order_id = $1\n              AND oi.quantity > oi.reserved_qty\n            ",
