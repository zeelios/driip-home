# ── Driip Production Environment ─────────────────────────────────────────────
# Copy this to .env.prod and fill in your actual values
# NEVER commit .env.prod to git!

# ── Database (Neon) ─────────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgres://driip:your_password@your-endpoint.ap-southeast-1.aws.neon.tech/driip?sslmode=require

# ── JWT Secrets (Generate with: openssl rand -hex 32) ──────────────────────────
JWT_SECRET=your_256_bit_secret_here_minimum_32_chars_long
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=604800

# ── Stripe (Optional but recommended for payments) ────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── GHTK Courier (Optional) ──────────────────────────────────────────────────
GHTK_TOKEN=your_ghtk_api_token
GHTK_WEBHOOK_SECRET=your_ghtk_webhook_secret
GHTK_PARTNER_CODE=your_partner_code
GHTK_SANDBOX=false

# GHTK Pickup Address (your warehouse)
GHTK_PICK_NAME=Driip Warehouse
GHTK_PICK_ADDRESS=123 Nguyen Van Linh
GHTK_PICK_PROVINCE=TP. Hồ Chí Minh
GHTK_PICK_DISTRICT=Quận 7
GHTK_PICK_TEL=0900000000

# ── Backblaze B2 (File Uploads) ───────────────────────────────────────────────
# All optional — uploads disabled if not configured
B2_ACCOUNT_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_application_key
B2_BUCKET_ID=your_b2_bucket_id
B2_BUCKET_NAME=your_b2_bucket_name
B2_CDN_URL=https://your-cdn-domain.com  # Optional: use custom CDN domain

# ── AWS (for deploy.sh) ─────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
FUNCTION_NAME=driip-api

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Ports (usually 8000 for Lambda, 3000 for local) ───────────────────────────
PORT=8000
