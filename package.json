{
  "name": "driip-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "home",
    "panel",
    "backend"
  ],
  "scripts": {
    "dev:home": "bun --cwd home dev",
    "build:home": "bun --cwd home build",
    "dev:panel": "bun --cwd panel dev",
    "dev:backend": "php artisan serve --host=0.0.0.0 --port=8000 --working-dir=backend"
  }
}
